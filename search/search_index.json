{"config":{"lang":["zh","en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\u673a\u5668\u4eba\u5f00\u53d1\u5b66\u4e60\u77e5\u8bc6\u5e93","text":"<p>\u8fd9\u91cc\u8bb0\u5f55\u6211\u7684\u673a\u5668\u4eba\u5f00\u53d1\u3001\u8ba1\u7b97\u673a\u57fa\u7840\u3001\u673a\u5668\u5b66\u4e60\u548c\u5de5\u7a0b\u5b9e\u8df5\u5b66\u4e60\u8fc7\u7a0b\u3002</p>"},{"location":"#_2","title":"\u5f53\u524d\u5b66\u4e60\u65b9\u5411","text":"<ul> <li>Python\u4e0eC++\u5de5\u7a0b\u80fd\u529b</li> <li>\u6570\u636e\u7ed3\u6784\u4e0e\u8ba1\u7b97\u673a\u57fa\u7840</li> <li>\u673a\u5668\u4eba\u8fd0\u52a8\u5b66\u4e0e\u5750\u6807\u53d8\u6362</li> <li>MuJoCo\u673a\u68b0\u81c2\u5b9e\u9a8c</li> <li>ROS 2\u7cfb\u7edf\u5f00\u53d1</li> <li>\u673a\u5668\u5b66\u4e60\u4e0e\u5f3a\u5316\u5b66\u4e60</li> <li>G1\u673a\u5668\u4eba\u4e52\u4e53\u7403\u9879\u76ee</li> </ul>"},{"location":"#_3","title":"\u5f53\u524d\u5b66\u4e60\u9636\u6bb5","text":"<p>\u6b63\u5728\u8fdb\u884c\u673a\u5668\u4eba\u5f00\u53d112\u5468\u7b2c\u4e00\u9636\u6bb5\u5b66\u4e60\u8ba1\u5212\u3002</p>"},{"location":"#_4","title":"\u77e5\u8bc6\u5e93\u7ed3\u6784","text":"\u5206\u533a \u5185\u5bb9 \u6bcf\u5468\u5b66\u4e60 \u6bcf\u5468\u8ba1\u5212\u3001\u5b8c\u6210\u60c5\u51b5\u548c\u590d\u76d8 \u7f16\u7a0b\u57fa\u7840 Python\u3001C++\u3001Linux\u3001Git \u673a\u5668\u4eba\u5b66 \u5750\u6807\u3001\u8fd0\u52a8\u5b66\u3001\u52a8\u529b\u5b66\u3001\u63a7\u5236 MuJoCo\u5b9e\u9a8c \u6a21\u578b\u3001\u8f68\u8ff9\u548c\u63a7\u5236\u5b9e\u9a8c \u673a\u5668\u5b66\u4e60 \u6df1\u5ea6\u5b66\u4e60\u3001\u5f3a\u5316\u5b66\u4e60\u3001\u6a21\u4eff\u5b66\u4e60 \u9879\u76ee G1\u4e52\u4e53\u7403\u7b49\u5b8c\u6574\u9879\u76ee\u8bb0\u5f55 \u8c03\u8bd5\u8bb0\u5f55 \u9519\u8bef\u73b0\u8c61\u3001\u539f\u56e0\u548c\u89e3\u51b3\u65b9\u6cd5 \u535a\u5ba2 \u9762\u5411\u516c\u5f00\u4ea4\u6d41\u7684\u9636\u6bb5\u6027\u6587\u7ae0"},{"location":"#_5","title":"\u6700\u8fd1\u66f4\u65b0","text":"<ul> <li>\u5efa\u7acb\u77e5\u8bc6\u5e93</li> <li>\u5f00\u59cb\u7b2c\u4e00\u5468\u5b66\u4e60</li> </ul>"},{"location":"tags/","title":"\u6807\u7b7e","text":"<p>\u8fd9\u91cc\u6309\u7167\u4e3b\u9898\u6c47\u603b\u77e5\u8bc6\u5e93\u4e2d\u7684\u6587\u7ae0\u3002</p>"},{"location":"test/","title":"\u6d4b\u8bd5\u9875\u9762","text":""},{"location":"test/#_2","title":"\u6570\u5b66\u516c\u5f0f","text":"<p>\u673a\u5668\u4eba\u52a8\u529b\u5b66\uff1a</p> \\[ \\tau=M(q)\\ddot q+C(q,\\dot q)\\dot q+g(q) \\]"},{"location":"test/#python","title":"Python\u4ee3\u7801","text":""},{"location":"test/#import-numpy-as-np-qnpzeros6-printq","title":"<pre><code>import numpy as np\n\nq=np.zeros(6)\n\nprint(q)\n</code></pre>","text":""},{"location":"test/#markdown","title":"\u5341\u4e09\u3001Markdown\u5e38\u7528\u5199\u6cd5","text":""},{"location":"test/#_3","title":"\u6807\u9898","text":"<p>markdown</p>"},{"location":"test/#_4","title":"\u4e00\u7ea7\u6807\u9898","text":""},{"location":"test/#_5","title":"\u4e8c\u7ea7\u6807\u9898","text":""},{"location":"test/#_6","title":"\u4e09\u7ea7\u6807\u9898","text":"<p>\u91cd\u8981\u5185\u5bb9</p> <p><code>\u53d8\u91cf\u540d</code></p> <p>\u8f7b\u5fae\u5f3a\u8c03</p> <pre><code>import numpy as np\n\nq = np.zeros(2)\n</code></pre> \u65b9\u6cd5 \u4f18\u70b9 \u7f3a\u70b9 P\u63a7\u5236 \u7b80\u5355 \u5bb9\u6613\u6709\u7a33\u6001\u8bef\u5dee PD\u63a7\u5236 \u6291\u5236\u632f\u8361 \u9700\u8981\u8c03\u53c2 <ul> <li> \u5b89\u88c5MuJoCo</li> <li> \u8fd0\u884c\u6700\u5c0f\u6a21\u578b</li> <li> \u8bfb\u53d6\u5173\u8282\u4f4d\u7f6e</li> <li> \u7ed8\u5236\u8f68\u8ff9</li> </ul> <p>\u8bf4\u660e</p> <p>\u8fd9\u91cc\u586b\u5199\u666e\u901a\u8865\u5145\u4fe1\u606f\u3002</p> <p>\u6ce8\u610f</p> <p>\u8fd9\u91cc\u586b\u5199\u5bb9\u6613\u51fa\u9519\u7684\u5185\u5bb9\u3002</p> <p>\u5371\u9669</p> <p>\u8fd9\u91cc\u586b\u5199\u53ef\u80fd\u5bfc\u81f4\u771f\u673a\u635f\u574f\u6216\u5b9e\u9a8c\u5931\u8d25\u7684\u5185\u5bb9\u3002</p> \u5c55\u5f00\u67e5\u770b\u793a\u4f8b <p>\u8fd9\u91cc\u586b\u5199\u53ef\u4ee5\u6298\u53e0\u7684\u4ee3\u7801\u6216\u8bf4\u660e\u3002</p> <p>\u53c2\u89c1\u673a\u68b0\u81c2\u8fd0\u52a8\u5b66\u3002</p>"},{"location":"blog/","title":"\u5b66\u4e60\u535a\u5ba2","text":"<p>\u8fd9\u91cc\u53d1\u5e03\u7ecf\u8fc7\u6574\u7406\u3001\u9002\u5408\u516c\u5f00\u9605\u8bfb\u548c\u8ba8\u8bba\u7684\u5b66\u4e60\u6587\u7ae0\u3002</p>"},{"location":"blog/2026/07/16/setup-mkdocs-github/","title":"Setup mkdocs github","text":"<p>\u597d\u7684\uff0c\u8fd9\u7bc7\u6211\u5efa\u8bae\u4f5c\u4e3a\u4f60\u77e5\u8bc6\u5e93\u7684\u7b2c\u4e00\u7bc7\u6b63\u5f0f\u535a\u5ba2/\u5de5\u7a0b\u8bb0\u5f55\uff0c\u800c\u4e0d\u662f\u7b80\u5355\u8bb0\u5f55\u201c\u5982\u4f55\u5b89\u88c5MkDocs\u201d\u3002\u56e0\u4e3a\u5b83\u5b9e\u9645\u4e0a\u5305\u542b\u4e86\u4f60\u4ee5\u540e\u673a\u5668\u4eba\u5f00\u53d1\u975e\u5e38\u91cd\u8981\u7684\u4e00\u5957\u5de5\u7a0b\u80fd\u529b\uff1a</p> <ul> <li>\u73af\u5883\u7ba1\u7406\uff08Conda\uff09</li> <li>\u6587\u6863\u5de5\u7a0b\uff08MkDocs\uff09</li> <li>\u7248\u672c\u63a7\u5236\uff08Git\uff09</li> <li>\u81ea\u52a8\u90e8\u7f72\uff08GitHub Actions\uff09</li> <li>\u5de5\u7a0b\u8c03\u8bd5\u601d\u7ef4</li> <li>AI\u8f85\u52a9\u5de5\u4f5c\u6d41</li> </ul> <p>\u6211\u6309\u7167\u4f60\u7684\u77e5\u8bc6\u5e93\u98ce\u683c\uff0c\u6574\u7406\u6210\u53ef\u4ee5\u76f4\u63a5\u653e\u5165\uff1a</p> <pre><code>docs/blog/setup-mkdocs-github.md\n</code></pre> <p>\u7684 Markdown \u6587\u4ef6\u3002</p> <pre><code># \u4f7f\u7528 MkDocs Material + GitHub Pages \u642d\u5efa\u4e2a\u4eba\u673a\u5668\u4eba\u5b66\u4e60\u77e5\u8bc6\u5e93\n\n&gt; \u65e5\u671f\uff1a2026-07-16  \n&gt; \u9879\u76ee\uff1arobot-learning-notes  \n&gt; \u76ee\u7684\uff1a\u5efa\u7acb\u957f\u671f\u7ef4\u62a4\u7684\u673a\u5668\u4eba\u3001\u4eba\u5de5\u667a\u80fd\u3001\u8ba1\u7b97\u673a\u77e5\u8bc6\u5e93\uff0c\u5e76\u5f62\u6210\u9ad8\u6548\u5b66\u4e60\u95ed\u73af\n\n---\n\n# 1. \u4e3a\u4ec0\u4e48\u5efa\u7acb\u4e2a\u4eba\u77e5\u8bc6\u5e93\uff1f\n\n\u968f\u7740\u673a\u5668\u4eba\u3001\u5927\u6a21\u578b\u3001\u5f3a\u5316\u5b66\u4e60\u7b49\u65b9\u5411\u5feb\u901f\u53d1\u5c55\uff0c\u4ec5\u4f9d\u9760\u96f6\u6563\u5b66\u4e60\u5df2\u7ecf\u96be\u4ee5\u5f62\u6210\u7cfb\u7edf\u80fd\u529b\u3002\n\n\u56e0\u6b64\u5efa\u7acb\u4e00\u4e2a\u957f\u671f\u7ef4\u62a4\u7684\u4e2a\u4eba\u77e5\u8bc6\u5e93\uff0c\u7528\u4e8e\uff1a\n\n- \u8bb0\u5f55\u5b66\u4e60\u8fc7\u7a0b\uff1b\n- \u603b\u7ed3\u6280\u672f\u539f\u7406\uff1b\n- \u4fdd\u5b58\u4ee3\u7801\u5b9e\u9a8c\uff1b\n- \u8bb0\u5f55\u9879\u76ee\u7ecf\u9a8c\uff1b\n- \u6c89\u6dc0Debug\u8fc7\u7a0b\uff1b\n- \u5f62\u6210\u672a\u6765\u9762\u8bd5\u548c\u79d1\u7814\u7684\u6280\u672f\u8d44\u4ea7\u3002\n\n\n\u4e00\u4e2a\u4f18\u79c0\u7684\u5de5\u7a0b\u5e08\u4e0d\u4ec5\u9700\u8981\uff1a\n\n&gt; \u4f1a\u5199\u4ee3\u7801\n\n\u66f4\u9700\u8981\uff1a\n\n&gt; \u80fd\u591f\u7ec4\u7ec7\u77e5\u8bc6\u3001\u7ba1\u7406\u9879\u76ee\u3001\u590d\u73b0\u95ee\u9898\u3001\u603b\u7ed3\u7ecf\u9a8c\u3002\n\n\n\u56e0\u6b64\uff0c\u672c\u77e5\u8bc6\u5e93\u91c7\u7528\uff1a\n</code></pre> <p>Markdown + MkDocs Material + Git + GitHub Actions + GitHub Pages</p> <pre><code>\u6784\u5efa\u3002\n\n---\n\n# 2. \u6700\u7ec8\u5de5\u4f5c\u6d41\u7a0b\n\n\u672a\u6765\u6240\u6709\u5b66\u4e60\u548c\u9879\u76ee\u8bb0\u5f55\u9075\u5faa\uff1a\n</code></pre> <p>\u5b66\u4e60/\u5b9e\u9a8c \u2193 \u6574\u7406Markdown\u7b14\u8bb0 \u2193 \u672c\u5730MkDocs\u9884\u89c8 \u2193 Git\u63d0\u4ea4\u7248\u672c \u2193 GitHub\u81ea\u52a8\u90e8\u7f72 \u2193 \u5728\u7ebf\u77e5\u8bc6\u5e93\u66f4\u65b0</p> <pre><code>\u5373\uff1a\n</code></pre> <p>write \u2192 preview \u2192 commit \u2192 push \u2192 deploy</p> <pre><code>---\n\n# 3. \u73af\u5883\u642d\u5efa\u8fc7\u7a0b\n\n## 3.1 \u521b\u5efaConda\u73af\u5883\n\n\u4e3a\u4e86\u907f\u514d\u4e0d\u540c\u9879\u76ee\u4e4b\u95f4Python\u4f9d\u8d56\u51b2\u7a81\uff0c\u5355\u72ec\u521b\u5efa\uff1a\n\n```powershell\nconda create -n robot-blog python=3.11 -y\n</code></pre> <p>\u6fc0\u6d3b\uff1a</p> <pre><code>conda activate robot-blog\n</code></pre> <p>\u68c0\u67e5\uff1a</p> <pre><code>python --version\n</code></pre> <p>\u8f93\u51fa\uff1a</p> <pre><code>Python 3.11.x\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#4","title":"4. \u9047\u5230\u7684\u95ee\u9898\u4e0e\u89e3\u51b3\u65b9\u6cd5","text":"","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#1conda-terms-of-service","title":"\u95ee\u98981\uff1aConda Terms of Service\u9519\u8bef","text":"<p>\u521b\u5efa\u73af\u5883\u65f6\u51fa\u73b0\uff1a</p> <pre><code>CondaToSNonInteractiveError\nTerms of Service have not been accepted\n</code></pre> <p>\u539f\u56e0\uff1a</p> <p>\u65b0\u7248Anaconda\u8981\u6c42\u7528\u6237\u786e\u8ba4\u9ed8\u8ba4channel\u670d\u52a1\u6761\u6b3e\u3002</p> <p>\u89e3\u51b3\uff1a</p> <p>\u6267\u884c\uff1a</p> <pre><code>conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main\n\nconda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r\n\nconda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/msys2\n</code></pre> <p>\u7136\u540e\u91cd\u65b0\u521b\u5efa\u73af\u5883\u3002</p>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#2conda-activate","title":"\u95ee\u98982\uff1aconda activate\u6ca1\u6709\u5207\u6362\u73af\u5883","text":"<p>\u73b0\u8c61\uff1a</p> <p>\u867d\u7136\uff1a</p> <pre><code>conda activate robot-blog\n</code></pre> <p>\u4f46\u662f\uff1a</p> <pre><code>python\n</code></pre> <p>\u4ecd\u7136\u6765\u81ea\uff1a</p> <pre><code>D:\\Python311\\python.exe\n</code></pre> <p>\u539f\u56e0\uff1a</p> <p>PowerShell\u6ca1\u6709\u52a0\u8f7dConda\u521d\u59cb\u5316\u811a\u672c\u3002</p> <p>\u89e3\u51b3\uff1a</p> <pre><code>conda init powershell\n</code></pre> <p>\u5173\u95edPowerShell\u91cd\u65b0\u6253\u5f00\u3002</p> <p>\u9a8c\u8bc1\uff1a</p> <pre><code>python -c \"import sys;print(sys.executable)\"\n</code></pre> <p>\u6b63\u786e\uff1a</p> <pre><code>D:\\Miniconda3\\envs\\robot-blog\\python.exe\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#5-mkdocs-material","title":"5. \u5b89\u88c5MkDocs Material","text":"<p>\u5b89\u88c5\uff1a</p> <pre><code>pip install mkdocs-material\n</code></pre> <p>\u68c0\u67e5\uff1a</p> <pre><code>mkdocs --version\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#6-mkdocs","title":"6. \u521b\u5efaMkDocs\u9879\u76ee","text":"<p>\u9879\u76ee\u7ed3\u6784\uff1a</p> <pre><code>robot-learning-notes\n\n\u251c\u2500\u2500 docs\n\u2502\n\u251c\u2500\u2500 mkdocs.yml\n\u2502\n\u2514\u2500\u2500 ...\n</code></pre> <p>\u542f\u52a8\uff1a</p> <pre><code>mkdocs serve\n</code></pre> <p>\u672c\u5730\u8bbf\u95ee\uff1a</p> <pre><code>http://127.0.0.1:8000/\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#7-mkdocs","title":"7. MkDocs\u76ee\u5f55\u7ba1\u7406","text":"<p>MkDocs\u901a\u8fc7\uff1a</p> <pre><code>mkdocs.yml\n</code></pre> <p>\u63a7\u5236\u7f51\u9875\u76ee\u5f55\u3002</p> <p>\u4f8b\u5982\uff1a</p> <pre><code>nav:\n\n  - \u9996\u9875:\n      - index.md\n\n  - \u673a\u5668\u4eba\u5b66:\n      - robotics/index.md\n      - \u8fd0\u52a8\u5b66:\n          - robotics/kinematics/index.md\n          - Jacobian:\n              robotics/kinematics/jacobian.md\n</code></pre> <p>\u6ce8\u610f\uff1a</p> <p>Linux\u73af\u5883\u4e2d\u8def\u5f84\u4f7f\u7528\uff1a</p> <pre><code>/\n</code></pre> <p>\u4e0d\u8981\u4f7f\u7528\uff1a</p> <pre><code>\\\n</code></pre> <p>\u5426\u5219GitHub Actions\u53ef\u80fd\u5931\u8d25\u3002</p>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#8-git","title":"8. Git\u7248\u672c\u7ba1\u7406","text":"","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#git","title":"\u521d\u59cb\u5316Git","text":"<pre><code>git init\n</code></pre> <p>\u6dfb\u52a0\uff1a</p> <pre><code>git add .\n</code></pre> <p>\u7b2c\u4e00\u6b21\u63d0\u4ea4\uff1a</p> <pre><code>git commit -m \"initialize robot knowledge base\"\n</code></pre> <p>\u8fde\u63a5Github\uff1a</p> <pre><code>git remote add origin &lt;repository-url&gt;\n</code></pre> <p>\u4e0a\u4f20\uff1a</p> <pre><code>git push origin main\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#9-github-actions","title":"9. GitHub Actions\u81ea\u52a8\u90e8\u7f72","text":"<p>\u521b\u5efa\uff1a</p> <pre><code>.github/workflows/deploy.yml\n</code></pre> <p>\u4f5c\u7528\uff1a</p> <p>\u6bcf\u6b21\uff1a</p> <pre><code>git push\n</code></pre> <p>\u81ea\u52a8\uff1a</p> <pre><code>Github\u670d\u52a1\u5668\n    \u2193\n\u5b89\u88c5MkDocs\n    \u2193\n\u751f\u6210\u7f51\u9875\n    \u2193\n\u90e8\u7f72Pages\n</code></pre> <p>\u56e0\u6b64\u4ee5\u540e\u65e0\u9700\u624b\u52a8\u4e0a\u4f20\u7f51\u7ad9\u3002</p>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#10","title":"10. \u90e8\u7f72\u8fc7\u7a0b\u4e2d\u9047\u5230\u7684\u95ee\u9898","text":"","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#github-actions","title":"\u95ee\u9898\uff1aGitHub Actions\u5931\u8d25","text":"<p>\u9519\u8bef\uff1a</p> <pre><code>Get Pages site failed\nHttpError: Not Found\n</code></pre> <p>\u539f\u56e0\uff1a</p> <p>Github Pages\u6ca1\u6709\u5b8c\u6210\u521d\u59cb\u5316\u3002</p> <p>\u89e3\u51b3\uff1a</p> <p>Settings</p> <p>\u2193</p> <p>Pages</p> <p>\u2193</p> <p>\u4e34\u65f6\u5207\u6362\uff1a</p> <pre><code>Deploy from branch\n</code></pre> <p>\u4fdd\u5b58</p> <p>\u2193</p> <p>\u5207\u56de\uff1a</p> <pre><code>GitHub Actions\n</code></pre> <p>\u91cd\u65b0\u89e6\u53d1workflow\u3002</p>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#11","title":"11. \u65e5\u5e38\u5de5\u4f5c\u6d41\u7a0b","text":"<p>\u4ee5\u540e\u5b66\u4e60\u673a\u5668\u4eba\u76f8\u5173\u77e5\u8bc6\u65f6\uff1a</p>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#step-1","title":"Step 1\uff1a\u5b66\u4e60","text":"<p>\u4f8b\u5982\uff1a</p> <p>\u673a\u68b0\u81c2Jacobian\u3002</p> <p>\u8bb0\u5f55\uff1a</p> <ul> <li>\u6982\u5ff5</li> <li>\u6570\u5b66\u516c\u5f0f</li> <li>\u63a8\u5bfc</li> <li>\u5b9e\u9a8c</li> </ul>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#step-2markdown","title":"Step 2\uff1a\u6574\u7406Markdown","text":"<p>\u4f8b\u5982\uff1a</p> <pre><code>docs/robotics/kinematics/jacobian.md\n</code></pre> <p>\u7ed3\u6784\uff1a</p> <pre><code># Jacobian\n\n\n## 1. \u57fa\u672c\u6982\u5ff5\n\n\n## 2. \u6570\u5b66\u63a8\u5bfc\n\n\n## 3. Python\u5b9e\u73b0\n\n\n## 4. MuJoCo\u5b9e\u9a8c\n\n\n## 5. \u5de5\u7a0b\u5e94\u7528\n\n\n## 6. \u9762\u8bd5\u95ee\u9898\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#step-3","title":"Step 3\uff1a\u672c\u5730\u68c0\u67e5","text":"<p>\u8fd0\u884c\uff1a</p> <pre><code>mkdocs serve\n</code></pre> <p>\u68c0\u67e5\uff1a</p> <ul> <li>\u56fe\u7247</li> <li>\u516c\u5f0f</li> <li>\u4ee3\u7801</li> <li>\u9875\u9762\u7ed3\u6784</li> </ul>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#step-4","title":"Step 4\uff1a\u63d0\u4ea4","text":"<pre><code>git add .\n\ngit commit -m \"docs: update jacobian notes\"\n\ngit push\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#12-ai","title":"12. \u5982\u4f55\u4f7f\u7528AI\u63d0\u5347\u5b66\u4e60\u6548\u7387","text":"<p>AI\u5e94\u8be5\u4f5c\u4e3a\uff1a</p> <p>\u601d\u8003\u8f85\u52a9\u5de5\u5177</p> <p>\u800c\u4e0d\u662f\uff1a</p> <p>\u66ff\u4ee3\u5b66\u4e60\u5de5\u5177\u3002</p>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#121-ai","title":"12.1 \u5b66\u4e60\u524d\uff1a\u8ba9AI\u751f\u6210\u5b66\u4e60\u8def\u7ebf","text":"<p>\u9519\u8bef\uff1a</p> <pre><code>\u4ec0\u4e48\u662fJacobian\uff1f\n</code></pre> <p>\u66f4\u597d\u7684\u65b9\u5f0f\uff1a</p> <pre><code>\u6211\u662f\u673a\u5668\u4eba\u4e13\u4e1a\u7814\u7a76\u751f\uff0c\n\u6b63\u5728\u5b66\u4e60\u673a\u68b0\u81c2Jacobian\u3002\n\n\u8bf7\u6309\u7167\uff1a\n1. \u6570\u5b66\u57fa\u7840\n2. \u673a\u5668\u4eba\u5e94\u7528\n3. Python\u5b9e\u73b0\n4. MuJoCo\u5b9e\u9a8c\n5. \u9762\u8bd5\u95ee\u9898\n\n\u8bbe\u8ba1\u5b66\u4e60\u8def\u7ebf\u3002\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#122-ai","title":"12.2 \u5b66\u4e60\u4e2d\uff1a\u8ba9AI\u5e2e\u52a9\u7406\u89e3","text":"<p>\u4f8b\u5982\uff1a</p> <pre><code>\u8bf7\u7ed3\u5408\u673a\u68b0\u81c2\u672b\u7aef\u901f\u5ea6\u63a7\u5236\u89e3\u91caJacobian\u3002\n\n\u4e0d\u8981\u53ea\u7ed9\u5b9a\u4e49\uff0c\n\u8bf7\u8bf4\u660e\uff1a\n\u4e3a\u4ec0\u4e48\u9700\u8981\u5b83\uff1f\n\u5982\u4f55\u8ba1\u7b97\uff1f\n\u5982\u4f55\u7528\u4e8e\u63a7\u5236\uff1f\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#123-aidebug","title":"12.3 \u7f16\u7a0b\u65f6\uff1aAI\u8f85\u52a9Debug","text":"<p>\u4e0d\u8981\uff1a</p> <pre><code>\u4ee3\u7801\u62a5\u9519\u600e\u4e48\u529e\uff1f\n</code></pre> <p>\u5e94\u8be5\uff1a</p> <pre><code>\u4e0b\u9762\u662f\u6211\u7684\u4ee3\u7801\u3002\n\n\u76ee\u6807\uff1a\n\u5b9e\u73b0\u673a\u68b0\u81c2IK\u3002\n\n\u73af\u5883\uff1a\nPython3.11\nPyTorch\nMuJoCo\n\n\u9519\u8bef\uff1a\nxxx\n\n\u8bf7\u5206\u6790\uff1a\n1. \u9519\u8bef\u539f\u56e0\n2. \u4fee\u6539\u65b9\u6848\n3. \u80cc\u540e\u7684\u539f\u7406\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#124-ai","title":"12.4 \u5b66\u4e60\u7ed3\u675f\uff1aAI\u6574\u7406\u77e5\u8bc6","text":"<p>\u6bcf\u5929\u7ed3\u675f\uff1a</p> <p>\u8f93\u5165\uff1a</p> <pre><code>\u6839\u636e\u6211\u7684\u5b66\u4e60\u7b14\u8bb0\uff0c\n\u5e2e\u6211\u6574\u7406\u6210MkDocs\u683c\u5f0fMarkdown\u3002\n\n\u8981\u6c42\uff1a\n- \u4fdd\u7559\u6211\u7684\u7406\u89e3\n- \u8865\u5145\u9057\u6f0f\u77e5\u8bc6\n- \u589e\u52a0\u9762\u8bd5\u95ee\u9898\n- \u589e\u52a0\u4ee3\u7801\u6848\u4f8b\n</code></pre> <p>\u7136\u540e\u4eba\u5de5\u4fee\u6539\u540e\u63d0\u4ea4\u3002</p>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#13-ai","title":"13. AI\u5de5\u5177\u4f7f\u7528\u539f\u5219","text":"","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#ai","title":"\u53ef\u4ee5\u4ea4\u7ed9AI\uff1a","text":"<ul> <li>\u67e5\u8be2\u8d44\u6599</li> <li>\u751f\u6210\u6a21\u677f</li> <li>Debug\u8f85\u52a9</li> <li>\u4ee3\u7801\u89e3\u91ca</li> <li>\u683c\u5f0f\u6574\u7406</li> </ul>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#ai_1","title":"\u4e0d\u5e94\u8be5\u5b8c\u5168\u4ea4\u7ed9AI\uff1a","text":"<ul> <li>\u6838\u5fc3\u7b97\u6cd5\u7406\u89e3</li> <li>\u6570\u5b66\u63a8\u5bfc</li> <li>\u9879\u76ee\u67b6\u6784\u8bbe\u8ba1</li> <li>\u79d1\u7814\u521b\u65b0\u601d\u8003</li> </ul> <p>\u76ee\u6807\uff1a</p> <pre><code>AI\u63d0\u9ad8\u6548\u7387\n+\n\u81ea\u5df1\u638c\u63e1\u80fd\u529b\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#14","title":"14. \u5f53\u524d\u77e5\u8bc6\u5e93\u89c4\u5212","text":"<pre><code>robot-learning-notes\n\n\u251c\u2500\u2500 weekly\n\u2502   \u2514\u2500\u2500 \u6bcf\u5468\u5b66\u4e60\u603b\u7ed3\n\n\n\u251c\u2500\u2500 programming\n\u2502   \u251c\u2500\u2500 Python\n\u2502   \u251c\u2500\u2500 C++\n\u2502   \u2514\u2500\u2500 Git\n\n\n\u251c\u2500\u2500 computer-science\n\u2502   \u251c\u2500\u2500 \u6570\u636e\u7ed3\u6784\n\u2502   \u251c\u2500\u2500 \u7b97\u6cd5\n\u2502   \u2514\u2500\u2500 \u64cd\u4f5c\u7cfb\u7edf\n\n\n\u251c\u2500\u2500 machine-learning\n\u2502   \u251c\u2500\u2500 Machine Learning\n\u2502   \u251c\u2500\u2500 Deep Learning\n\u2502   \u2514\u2500\u2500 PyTorch\n\n\n\u251c\u2500\u2500 robotics\n\u2502   \u251c\u2500\u2500 Kinematics\n\u2502   \u251c\u2500\u2500 Dynamics\n\u2502   \u251c\u2500\u2500 Control\n\u2502   \u2514\u2500\u2500 ROS2\n\n\n\u251c\u2500\u2500 mujoco\n\n\u251c\u2500\u2500 projects\n\u2502   \u251c\u2500\u2500 Robot PingPong\n\u2502   \u2514\u2500\u2500 Other Projects\n\n\n\u2514\u2500\u2500 debugging\n    \u2514\u2500\u2500 \u95ee\u9898\u8bb0\u5f55\n</code></pre>","tags":["MkDocs","GitHub","Git"]},{"location":"blog/2026/07/16/setup-mkdocs-github/#15","title":"15. \u603b\u7ed3","text":"<p>\u901a\u8fc7\u642d\u5efa\u8fd9\u4e2a\u77e5\u8bc6\u5e93\uff0c\u5b8c\u6210\u4e86\uff1a</p> <ul> <li>Python\u73af\u5883\u7ba1\u7406</li> <li>Conda\u4f7f\u7528</li> <li>MkDocs\u6587\u6863\u5de5\u7a0b</li> <li>Git\u7248\u672c\u7ba1\u7406</li> <li>GitHub Actions\u81ea\u52a8\u90e8\u7f72</li> <li>Markdown\u77e5\u8bc6\u6574\u7406</li> </ul> <p>\u672a\u6765\u6240\u6709\u673a\u5668\u4eba\u5b66\u4e60\u3001\u79d1\u7814\u9879\u76ee\u3001\u4ee3\u7801\u5b9e\u9a8c\uff0c\u90fd\u5c06\u5728\u8fd9\u4e2a\u4f53\u7cfb\u4e2d\u6301\u7eed\u79ef\u7d2f\u3002</p> <p>\u6700\u7ec8\u76ee\u6807\uff1a</p> <p>\u5efa\u7acb\u4e00\u4e2a\u5c5e\u4e8e\u81ea\u5df1\u7684\uff1a</p> <p>Robotics + AI + Computer Science \u6280\u672f\u77e5\u8bc6\u5e93\u3002</p> <pre><code>---\n\n\u8fd9\u7bc7\u5efa\u8bae\u4f60\u4fdd\u5b58\u4e3a\uff1a\n</code></pre> <p>docs/blog/setup-mkdocs-github.md</p> <pre><code>\u5e76\u4e14\u5728 `mkdocs.yml` \u52a0\u5165\uff1a\n\n```yaml\n- \u535a\u5ba2:\n    - \u642d\u5efa\u4e2a\u4eba\u77e5\u8bc6\u5e93: blog/setup-mkdocs-github.md\n</code></pre> <p>\u4ee5\u540e\u4f60\u6bcf\u6b21\u9047\u5230\u73af\u5883\u3001\u5de5\u5177\u3001\u5de5\u7a0b\u6d41\u7a0b\u95ee\u9898\uff0c\u90fd\u53ef\u4ee5\u7ee7\u7eed\u8ffd\u52a0\u5230\uff1a</p> <pre><code>docs/debugging/\n</code></pre> <p>\u8fd9\u4f1a\u9010\u6e10\u53d8\u6210\u4f60\u975e\u5e38\u6709\u4ef7\u503c\u7684\u201c\u5de5\u7a0b\u8e29\u5751\u6570\u636e\u5e93\u201d\u3002\u4f60\u4eca\u5929\u642d\u5efa\u535a\u5ba2\u7684\u8fc7\u7a0b\uff0c\u5176\u5b9e\u6b63\u597d\u6210\u4e3a\u4e86\u4f60\u673a\u5668\u4eba\u5f00\u53d1\u5b66\u4e60\u8def\u7ebf\u91cc\u7684\u7b2c\u4e00\u4e2a\u5de5\u7a0b\u9879\u76ee\u3002</p>","tags":["MkDocs","GitHub","Git"]},{"location":"mujoco/trajectory/","title":"\u8f68\u8ff9\u89c4\u5212","text":"<p>tags:   - MuJoCo   - \u8f68\u8ff9\u89c4\u5212   - Python</p>"},{"location":"robotics/kinematics/jacobian/","title":"\u673a\u68b0\u81c2Jacobian\u57fa\u7840","text":"","tags":["\u673a\u5668\u4eba\u5b66","\u8fd0\u52a8\u5b66","Jacobian"]},{"location":"robotics/kinematics/jacobian/#1","title":"1. \u95ee\u9898\u80cc\u666f","text":"<p>\u673a\u68b0\u81c2\u5173\u8282\u901f\u5ea6\u5982\u4f55\u5f71\u54cd\u672b\u7aef\u901f\u5ea6\uff1f</p>","tags":["\u673a\u5668\u4eba\u5b66","\u8fd0\u52a8\u5b66","Jacobian"]},{"location":"robotics/kinematics/jacobian/#2","title":"2. \u95ee\u9898\u5b9a\u4e49","text":"<p>\u7ed9\u5b9a\u5173\u8282\u89d2\uff1a</p> \\[ q=[q_1,q_2,\\ldots,q_n]^T \\] <p>\u672b\u7aef\u4f4d\u7f6e\uff1a</p> \\[ x=f(q) \\] <p>\u5e0c\u671b\u5f97\u5230\u5173\u8282\u901f\u5ea6\u4e0e\u672b\u7aef\u901f\u5ea6\u4e4b\u95f4\u7684\u5173\u7cfb\u3002</p>","tags":["\u673a\u5668\u4eba\u5b66","\u8fd0\u52a8\u5b66","Jacobian"]},{"location":"robotics/kinematics/jacobian/#3","title":"3. \u6838\u5fc3\u539f\u7406","text":"\\[ \\dot{x}=J(q)\\dot{q} \\] <p>\u5176\u4e2d\uff1a</p> <ul> <li>\\(q\\)\uff1a\u5173\u8282\u89d2\uff1b</li> <li>\\(\\dot{q}\\)\uff1a\u5173\u8282\u901f\u5ea6\uff1b</li> <li>\\(x\\)\uff1a\u672b\u7aef\u72b6\u6001\uff1b</li> <li>\\(J(q)\\)\uff1aJacobian\u77e9\u9635\u3002</li> </ul>","tags":["\u673a\u5668\u4eba\u5b66","\u8fd0\u52a8\u5b66","Jacobian"]},{"location":"robotics/kinematics/jacobian/#4","title":"4. \u6700\u5c0f\u5b9e\u73b0","text":"<p>```python import numpy as np</p> <p>def numerical_jacobian(     forward_kinematics,     q: np.ndarray,     epsilon: float = 1e-6, ) -&gt; np.ndarray:     \"\"\"\u4f7f\u7528\u4e2d\u5fc3\u5dee\u5206\u8ba1\u7b97\u6570\u503c Jacobian\u3002\"\"\"     if epsilon &lt;= 0:         raise ValueError(\"epsilon must be positive\")</p> <pre><code>q = np.asarray(q, dtype=float)\nx0 = np.asarray(forward_kinematics(q), dtype=float)\n\njacobian = np.zeros((x0.size, q.size), dtype=float)\n\nfor index in range(q.size):\n    q_plus = q.copy()\n    q_minus = q.copy()\n\n    q_plus[index] += epsilon\n    q_minus[index] -= epsilon\n\n    x_plus = np.asarray(forward_kinematics(q_plus), dtype=float)\n    x_minus = np.asarray(forward_kinematics(q_minus), dtype=float)\n\n    jacobian[:, index] = (\n        x_plus - x_minus\n    ) / (2.0 * epsilon)\n\nreturn jacobian\n</code></pre>","tags":["\u673a\u5668\u4eba\u5b66","\u8fd0\u52a8\u5b66","Jacobian"]},{"location":"weekly/","title":"\u6bcf\u5468\u5b66\u4e60\u8bb0\u5f55","text":"<p>\u8fd9\u91cc\u6309\u7167\u65f6\u95f4\u8bb0\u5f55\u6bcf\u5468\u7684\u5b66\u4e60\u76ee\u6807\u3001\u5b8c\u6210\u60c5\u51b5\u548c\u590d\u76d8\u3002</p>"},{"location":"weekly/#_2","title":"\u7b2c\u4e00\u9636\u6bb5","text":"<ul> <li>\u7b2c\u4e00\u5468</li> </ul>"},{"location":"weekly/week-01/","title":"\u7b2c\u4e00\u5468\u5b66\u4e60\u8bb0\u5f55","text":"","tags":["\u5468\u62a5","Linux","Git","Python","MuJoCo"]},{"location":"weekly/week-01/#_2","title":"\u672c\u5468\u76ee\u6807","text":"<ul> <li> \u719f\u6089Linux\u57fa\u7840\u547d\u4ee4</li> <li> \u638c\u63e1Git\u57fa\u7840\u5de5\u4f5c\u6d41</li> <li> \u7406\u89e3\u673a\u5668\u4eba\u7cfb\u7edf\u57fa\u672c\u6a21\u5757</li> <li> \u5b8c\u6210\u7b2c\u4e00\u4e2aMuJoCo\u5b9e\u9a8c</li> <li> \u5b8c\u6210\u4e00\u4e2a\u5c0f\u578b\u8f68\u8ff9\u5904\u7406\u7a0b\u5e8f</li> </ul>","tags":["\u5468\u62a5","Linux","Git","Python","MuJoCo"]},{"location":"weekly/week-01/#_3","title":"\u6bcf\u65e5\u8fdb\u5ea6","text":"","tags":["\u5468\u62a5","Linux","Git","Python","MuJoCo"]},{"location":"weekly/week-01/#_4","title":"\u5468\u4e00","text":"","tags":["\u5468\u62a5","Linux","Git","Python","MuJoCo"]},{"location":"weekly/week-01/#_5","title":"\u5b66\u4e60\u5185\u5bb9","text":"","tags":["\u5468\u62a5","Lin